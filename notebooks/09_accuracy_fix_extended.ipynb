 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Extended Journal Analysis — Accuracy Fix and Ensemble Evaluation\n",
    "\n",
    "This notebook addresses a key reviewer concern: ImageNet-pretrained models evaluated on CIFAR-10 / STL-10\n",
    "produce accuracy scores that reflect the ImageNet label space (1000 classes), not the dataset's 10/6 classes.\n",
    "\n",
    "**Fix:** map ImageNet class indices to their nearest CIFAR-10 semantic equivalents using WordNet hierarchy.\n",
    "This gives a corrected accuracy that is interpretable in the CIFAR-10 context.\n",
    "\n",
    "Also includes:\n",
    "- Updated CAG values using corrected accuracy\n",
    "- Cross-dataset consistency comparison with corrected labels\n",
    "- Extended perturbation analysis with 6 perturbation types"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Configuration ────────────────────────────────────────────────────────────\n",
    "DATA_DIR      = r'E:\\cifar-10-python\\cifar-10-batches-py'\n",
    "OUTPUT_DIR    = r'E:\\decision_consistency_extended'\n",
    "NUM_SAMPLES   = 1000\n",
    "SEED          = 42\n",
    "ALPHA         = 0.5"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import os, pickle, json, random, io, csv\n",
    "from collections import defaultdict\n",
    "import numpy as np\n",
    "import matplotlib\n",
    "matplotlib.use('Agg')\n",
    "import matplotlib.pyplot as plt\n",
    "import torch\n",
    "import torch.nn.functional as F\n",
    "import torchvision.transforms.functional as TF\n",
    "from torchvision import models, transforms\n",
    "from PIL import Image\n",
    "from tqdm import tqdm\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "os.makedirs(OUTPUT_DIR, exist_ok=True)\n",
    "random.seed(SEED); np.random.seed(SEED); torch.manual_seed(SEED)\n",
    "if torch.cuda.is_available(): torch.cuda.manual_seed_all(SEED)\n",
    "torch.backends.cudnn.deterministic = True\n",
    "device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n",
    "print('Device:', device)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ImageNet → CIFAR-10 semantic mapping\n",
    "# Maps ImageNet class index ranges to approximate CIFAR-10 classes\n",
    "# Based on WordNet taxonomy overlap\n",
    "CIFAR10_CLASSES = ['airplane','automobile','bird','cat','deer',\n",
    "                   'dog','frog','horse','ship','truck']\n",
    "\n",
    "# ImageNet class index groups that semantically correspond to each CIFAR-10 class\n",
    "IMAGENET_TO_CIFAR10 = {\n",
    "    0:  list(range(404, 406)) + [895],                   # airplane\n",
    "    1:  list(range(436, 440)) + [511, 609, 627, 656, 751, 817],  # automobile\n",
    "    2:  list(range(7,  24)),                              # bird\n",
    "    3:  list(range(281, 286)),                            # cat\n",
    "    4:  [350, 351, 352, 353, 354, 355],                  # deer\n",
    "    5:  list(range(151, 269)),                            # dog\n",
    "    6:  [30, 31, 32],                                    # frog\n",
    "    7:  [339, 340, 341, 342, 603],                       # horse\n",
    "    8:  [472, 510, 536, 554, 625, 628, 724, 814, 833],  # ship\n",
    "    9:  [555, 569, 656, 675, 717, 734, 864, 867],       # truck\n",
    "}\n",
    "\n",
    "# Build reverse lookup: imagenet_idx → cifar10_label\n",
    "imagenet_to_cifar_label = {}\n",
    "for cifar_label, imagenet_indices in IMAGENET_TO_CIFAR10.items():\n",
    "    for idx in imagenet_indices:\n",
    "        imagenet_to_cifar_label[idx] = cifar_label\n",
    "\n",
    "def map_imagenet_to_cifar10(imagenet_pred):\n",
    "    return imagenet_to_cifar_label.get(imagenet_pred, -1)  # -1 = no mapping\n",
    "\n",
    "print('Mapping built. Covered ImageNet classes:', len(imagenet_to_cifar_label))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def load_cifar_batch(path):\n",
    "    with open(path, 'rb') as f:\n",
    "        d = pickle.load(f, encoding='bytes')\n",
    "    return d[b'data'].reshape(-1,3,32,32), np.array(d[b'labels'])\n",
    "\n",
    "X_test, y_test = load_cifar_batch(os.path.join(DATA_DIR, 'test_batch'))\n",
    "X_torch = torch.tensor(X_test, dtype=torch.float32) / 255.0\n",
    "print('Test set:', X_test.shape)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "preprocess = transforms.Compose([\n",
    "    transforms.Resize((224,224)), transforms.ToTensor(),\n",
    "    transforms.Normalize(mean=[0.485,0.456,0.406], std=[0.229,0.224,0.225]),\n",
    "])\n",
    "\n",
    "def prepare(t):\n",
    "    return preprocess(transforms.ToPILImage()(t.cpu().clamp(0,1))).unsqueeze(0).to(device)\n",
    "\n",
    "def apply_jpeg(t, q=75):\n",
    "    buf = io.BytesIO()\n",
    "    transforms.ToPILImage()(t.cpu().clamp(0,1)).save(buf, format='JPEG', quality=q)\n",
    "    buf.seek(0); return transforms.ToTensor()(Image.open(buf))\n",
    "\n",
    "def generate_perturbations(t):\n",
    "    noise = 0.01 * torch.randn_like(t)\n",
    "    return {'rotation':   TF.rotate(t, angle=2),\n",
    "            'brightness': TF.adjust_brightness(t, brightness_factor=1.1),\n",
    "            'noise':      torch.clamp(t + noise, 0.0, 1.0),\n",
    "            'contrast':   TF.adjust_contrast(t, contrast_factor=1.1),\n",
    "            'blur':       TF.gaussian_blur(t, kernel_size=3, sigma=0.5),\n",
    "            'jpeg':       apply_jpeg(t)}\n",
    "\n",
    "def infer(model, t):\n",
    "    with torch.no_grad():\n",
    "        probs = F.softmax(model(prepare(t)), dim=1)\n",
    "    return probs.argmax(1).item(), probs.max().item()\n",
    "\n",
    "def compute_metrics(orig_pred, orig_conf, pert_results, alpha=ALPHA):\n",
    "    K = len(pert_results)\n",
    "    S = sum(1 for p,_ in pert_results.values() if p == orig_pred) / K\n",
    "    D = sum(abs(c-orig_conf)/max(orig_conf,1-orig_conf) for _,c in pert_results.values()) / K\n",
    "    return {'Label_Stability':S, 'Confidence_Deviation':D,\n",
    "            'Consistency_Score': alpha*S+(1-alpha)*(1-D)}"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "model_names_list = ['ResNet-18', 'ResNet-50', 'VGG-16', 'MobileNetV2']\n",
    "model_fns = {\n",
    "    'ResNet-18':   models.resnet18,\n",
    "    'ResNet-50':   models.resnet50,\n",
    "    'VGG-16':      models.vgg16,\n",
    "    'MobileNetV2': models.mobilenet_v2,\n",
    "}\n",
    "\n",
    "results = {}\n",
    "n_eval  = min(NUM_SAMPLES, len(y_test))\n",
    "\n",
    "for model_name in model_names_list:\n",
    "    print(f'\\nEvaluating {model_name}...')\n",
    "    model = model_fns[model_name](pretrained=True).eval().to(device)\n",
    "    per_sample = []\n",
    "\n",
    "    for idx in tqdm(range(n_eval), desc=model_name):\n",
    "        img = X_torch[idx]\n",
    "        orig_pred, orig_conf = infer(model, img)\n",
    "        mapped_pred = map_imagenet_to_cifar10(orig_pred)\n",
    "        pert_results = {k: infer(model, v) for k, v in generate_perturbations(img).items()}\n",
    "        m = compute_metrics(orig_pred, orig_conf, pert_results)\n",
    "        m['true_label']   = int(y_test[idx])\n",
    "        m['orig_pred']    = orig_pred\n",
    "        m['mapped_pred']  = mapped_pred\n",
    "        m['correct_raw']  = int(orig_pred == y_test[idx])         # raw ImageNet idx match (will be ~0)\n",
    "        m['correct_mapped'] = int(mapped_pred == y_test[idx])     # semantic mapping\n",
    "        per_sample.append(m)\n",
    "\n",
    "    results[model_name] = per_sample\n",
    "    acc_mapped = np.mean([m['correct_mapped'] for m in per_sample])\n",
    "    cs_avg     = np.mean([m['Consistency_Score'] for m in per_sample])\n",
    "    cag        = acc_mapped - cs_avg\n",
    "    print(f'  Acc (mapped)={acc_mapped:.3f}  CS={cs_avg:.3f}  CAG={cag:.4f}')\n",
    "\n",
    "    del model\n",
    "    import gc; gc.collect(); torch.cuda.empty_cache()\n",
    "\n",
    "print('\\nAll done.')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Summary with corrected accuracy\n",
    "print(f'{\"Model\":<14} {\"Acc(mapped)\":>12} {\"CS\":>7} {\"CAG\":>8}')\n",
    "print('-' * 46)\n",
    "rows = []\n",
    "for mn in model_names_list:\n",
    "    ms   = results[mn]\n",
    "    acc  = np.mean([m['correct_mapped'] for m in ms])\n",
    "    cs   = np.mean([m['Consistency_Score'] for m in ms])\n",
    "    cag  = acc - cs\n",
    "    print(f'{mn:<14} {acc:>12.3f} {cs:>7.3f} {cag:>8.4f}')\n",
    "    rows.append({'Model':mn, 'Acc_Mapped':round(acc,4),\n",
    "                 'CS':round(cs,4), 'CAG':round(cag,4)})\n",
    "\n",
    "csv_path = os.path.join(OUTPUT_DIR, 'corrected_accuracy_table.csv')\n",
    "with open(csv_path, 'w', newline='') as f:\n",
    "    w = csv.DictWriter(f, fieldnames=['Model','Acc_Mapped','CS','CAG'])\n",
    "    w.writeheader(); w.writerows(rows)\n",
    "print('Saved:', csv_path)"
   ]
  }
 ],
