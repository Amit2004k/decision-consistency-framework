 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Fine-Tune Last Layer — Consistency Impact Analysis\n",
    "\n",
    "Investigates whether fine-tuning only the final classification layer of pretrained CNNs\n",
    "improves decision consistency compared to the zero-shot (feature extractor only) baseline.\n",
    "\n",
    "Experiments:\n",
    "- Freeze all layers except the final FC layer\n",
    "- Fine-tune on a small subset of CIFAR-10 training data\n",
    "- Re-evaluate CS, LS, CD after fine-tuning\n",
    "- Compare vs pretrained (no fine-tune) baseline from notebook 01\n",
    "\n",
    "**Update paths before running.**"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Configuration ────────────────────────────────────────────────────────────\n",
    "DATA_DIR   = r'E:\\cifar-10-python\\cifar-10-batches-py'\n",
    "OUTPUT_DIR = r'E:\\decision_consistency_finetune'\n",
    "NUM_FINETUNE_SAMPLES = 5000  # samples used for fine-tuning (10% of train)\n",
    "NUM_EVAL_SAMPLES     = 500\n",
    "EPOCHS = 5\n",
    "LR     = 1e-3\n",
    "SEED   = 42"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import os, pickle, json, random\n",
    "import numpy as np\n",
    "import torch\n",
    "import torch.nn as nn\n",
    "import torch.nn.functional as F\n",
    "import torchvision.transforms.functional as TF\n",
    "from torchvision import models, transforms\n",
    "from torch.utils.data import DataLoader, TensorDataset\n",
    "from PIL import Image\n",
    "import matplotlib\n",
    "matplotlib.use('Agg')\n",
    "import matplotlib.pyplot as plt\n",
    "from tqdm import tqdm\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "os.makedirs(OUTPUT_DIR, exist_ok=True)\n",
    "random.seed(SEED); np.random.seed(SEED); torch.manual_seed(SEED)\n",
    "if torch.cuda.is_available(): torch.cuda.manual_seed_all(SEED)\n",
    "torch.backends.cudnn.deterministic = True\n",
    "device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n",
    "print('Device:', device)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def load_cifar_batch(path):\n",
    "    with open(path, 'rb') as f:\n",
    "        d = pickle.load(f, encoding='bytes')\n",
    "    return d[b'data'].reshape(-1,3,32,32), np.array(d[b'labels'])\n",
    "\n",
    "# Load all training batches\n",
    "X_train_list, y_train_list = [], []\n",
    "for i in range(1, 6):\n",
    "    X, y = load_cifar_batch(os.path.join(DATA_DIR, f'data_batch_{i}'))\n",
    "    X_train_list.append(X); y_train_list.append(y)\n",
    "X_train = np.concatenate(X_train_list)\n",
    "y_train = np.concatenate(y_train_list)\n",
    "X_test, y_test = load_cifar_batch(os.path.join(DATA_DIR, 'test_batch'))\n",
    "print('Train:', X_train.shape, '  Test:', X_test.shape)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "preprocess = transforms.Compose([\n",
    "    transforms.Resize((224,224)), transforms.ToTensor(),\n",
    "    transforms.Normalize(mean=[0.485,0.456,0.406], std=[0.229,0.224,0.225]),\n",
    "])\n",
    "\n",
    "def to_tensor_batch(X_np):\n",
    "    \"\"\"Convert (N,3,32,32) uint8 → batch of preprocessed tensors.\"\"\"\n",
    "    tensors = []\n",
    "    for img in X_np:\n",
    "        pil = transforms.ToPILImage()(torch.tensor(img, dtype=torch.float32)/255.0)\n",
    "        tensors.append(preprocess(pil))\n",
    "    return torch.stack(tensors)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Fine-tune last layer only\n",
    "def build_finetuned_model(device, num_classes=10):\n",
    "    model = models.resnet18(pretrained=True)\n",
    "    # Freeze all layers\n",
    "    for param in model.parameters():\n",
    "        param.requires_grad = False\n",
    "    # Replace and unfreeze the final FC\n",
    "    in_features = model.fc.in_features\n",
    "    model.fc = nn.Linear(in_features, num_classes)\n",
    "    return model.to(device)\n",
    "\n",
    "ft_model = build_finetuned_model(device)\n",
    "print('Trainable params:', sum(p.numel() for p in ft_model.parameters() if p.requires_grad))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Prepare fine-tune dataset\n",
    "idx_ft = np.random.choice(len(X_train), NUM_FINETUNE_SAMPLES, replace=False)\n",
    "X_ft_np = X_train[idx_ft]\n",
    "y_ft    = torch.tensor(y_train[idx_ft], dtype=torch.long)\n",
    "\n",
    "print('Preprocessing fine-tune images...')\n",
    "X_ft_t = to_tensor_batch(X_ft_np)\n",
    "train_ds = TensorDataset(X_ft_t, y_ft)\n",
    "train_dl = DataLoader(train_ds, batch_size=64, shuffle=True)\n",
    "print(f'Fine-tune dataset: {len(train_ds)} images')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "optimizer = torch.optim.Adam(ft_model.fc.parameters(), lr=LR)\n",
    "criterion = nn.CrossEntropyLoss()\n",
    "\n",
    "ft_model.train()\n",
    "for epoch in range(EPOCHS):\n",
    "    total_loss, correct, total = 0, 0, 0\n",
    "    for X_batch, y_batch in tqdm(train_dl, desc=f'Epoch {epoch+1}/{EPOCHS}', leave=False):\n",
    "        X_batch, y_batch = X_batch.to(device), y_batch.to(device)\n",
    "        optimizer.zero_grad()\n",
    "        out  = ft_model(X_batch)\n",
    "        loss = criterion(out, y_batch)\n",
    "        loss.backward()\n",
    "        optimizer.step()\n",
    "        total_loss += loss.item() * len(y_batch)\n",
    "        correct    += (out.argmax(1) == y_batch).sum().item()\n",
    "        total      += len(y_batch)\n",
    "    print(f'Epoch {epoch+1}: loss={total_loss/total:.4f}  acc={correct/total:.3f}')\n",
    "ft_model.eval()\n",
    "print('Fine-tuning complete.')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Evaluate consistency before and after fine-tuning\n",
    "def apply_jpeg(t, q=75):\n",
    "    import io\n",
    "    buf = io.BytesIO()\n",
    "    transforms.ToPILImage()(t.cpu().clamp(0,1)).save(buf, format='JPEG', quality=q)\n",
    "    buf.seek(0); return transforms.ToTensor()(Image.open(buf))\n",
    "\n",
    "def generate_perturbations(t):\n",
    "    noise = 0.01 * torch.randn_like(t)\n",
    "    return {'rotation':   TF.rotate(t, angle=2),\n",
    "            'brightness': TF.adjust_brightness(t, brightness_factor=1.1),\n",
    "            'noise':      torch.clamp(t + noise, 0.0, 1.0),\n",
    "            'contrast':   TF.adjust_contrast(t, contrast_factor=1.1),\n",
    "            'blur':       TF.gaussian_blur(t, kernel_size=3, sigma=0.5),\n",
    "            'jpeg':       apply_jpeg(t)}\n",
    "\n",
    "def prepare(t, dev):\n",
    "    return preprocess(transforms.ToPILImage()(t.cpu().clamp(0,1))).unsqueeze(0).to(dev)\n",
    "\n",
    "def infer_model(model, t, dev):\n",
    "    with torch.no_grad():\n",
    "        probs = F.softmax(model(prepare(t, dev)), dim=1)\n",
    "    return probs.argmax(1).item(), probs.max().item()\n",
    "\n",
    "def eval_consistency(model, X_np, n, dev, alpha=0.5):\n",
    "    X_t = torch.tensor(X_np[:n], dtype=torch.float32) / 255.0\n",
    "    metrics = []\n",
    "    for img in tqdm(X_t, desc='Eval', leave=False):\n",
    "        op, oc = infer_model(model, img, dev)\n",
    "        pr = {k: infer_model(model, v, dev) for k, v in generate_perturbations(img).items()}\n",
    "        K = len(pr)\n",
    "        S = sum(1 for p,_ in pr.values() if p == op) / K\n",
    "        D = sum(abs(c-oc)/max(oc,1-oc) for _,c in pr.values()) / K\n",
    "        metrics.append({'LS':S, 'CD':D, 'CS': alpha*S+(1-alpha)*(1-D)})\n",
    "    return metrics\n",
    "\n",
    "# Pre-trained baseline (ImageNet weights, no fine-tune)\n",
    "pretrained = models.resnet18(pretrained=True).eval().to(device)\n",
    "\n",
    "print('Evaluating pretrained...')\n",
    "m_pretrained = eval_consistency(pretrained, X_test, NUM_EVAL_SAMPLES, device)\n",
    "print('Evaluating fine-tuned...')\n",
    "m_finetuned  = eval_consistency(ft_model,  X_test, NUM_EVAL_SAMPLES, device)\n",
    "\n",
    "print('\\n          Pretrained   Fine-tuned')\n",
    "print('LS        {:.3f}        {:.3f}'.format(\n",
    "      np.mean([m['LS'] for m in m_pretrained]),\n",
    "      np.mean([m['LS'] for m in m_finetuned])))\n",
    "print('CD        {:.3f}        {:.3f}'.format(\n",
    "      np.mean([m['CD'] for m in m_pretrained]),\n",
    "      np.mean([m['CD'] for m in m_finetuned])))\n",
    "print('CS        {:.3f}        {:.3f}'.format(\n",
    "      np.mean([m['CS'] for m in m_pretrained]),\n",
    "      np.mean([m['CS'] for m in m_finetuned])))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Side-by-side CS distribution\n",
    "cs_pre = [m['CS'] for m in m_pretrained]\n",
    "cs_ft  = [m['CS'] for m in m_finetuned]\n",
    "\n",
    "fig, axes = plt.subplots(1, 2, figsize=(10, 4), sharey=True)\n",
    "for ax, vals, title in [\n",
    "    (axes[0], cs_pre, f'Pretrained (no fine-tune)\\nMean={np.mean(cs_pre):.3f}'),\n",
    "    (axes[1], cs_ft,  f'Fine-tuned last layer\\nMean={np.mean(cs_ft):.3f}'),\n",
    "]:\n",
    "    ax.hist(vals, bins=20, color='steelblue', edgecolor='white')\n",
    "    ax.axvline(np.mean(vals), color='red', linestyle='--', lw=1.5)\n",
    "    ax.set_xlabel('Consistency Score'); ax.set_title(title, fontsize=10)\n",
    "    ax.set_xlim(0,1); ax.grid(alpha=0.3)\n",
    "axes[0].set_ylabel('Frequency')\n",
    "fig.suptitle('Effect of Last-Layer Fine-Tuning on Decision Consistency\\nResNet-18 / CIFAR-10', fontsize=11)\n",
    "plt.tight_layout()\n",
    "path = os.path.join(OUTPUT_DIR, 'finetune_vs_pretrained_cs.png')\n",
    "plt.savefig(path, dpi=300, bbox_inches='tight'); plt.close()\n",
    "print('Saved:', path)"
   ]
  }
 ],
