 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Linear Probe + ECE — Corrected Accuracy with Real Labels\n",
    "\n",
    "Computes **true task accuracy** using a linear probe trained on dataset-specific labels,\n",
    "bypassing the ImageNet class space mismatch that affects zero-shot accuracy.\n",
    "\n",
    "Steps:\n",
    "1. Freeze pretrained backbone (ResNet-18/50, VGG-16, MobileNetV2)\n",
    "2. Train a linear classification head on dataset training split (3 epochs)\n",
    "3. Evaluate on test split: accuracy + ECE\n",
    "4. Merge with DCF consistency scores to compute **corrected CAG**\n",
    "\n",
    "Datasets: CIFAR-10, STL-10, Intel Scene, OCTMNIST\n",
    "\n",
    "**Prereq:** run notebooks 01–03 and 11 first so consistency CSVs exist."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Configuration ────────────────────────────────────────────────────────────\n",
    "CIFAR_ROOT   = r'E:\\cifar-10-python'\n",
    "STL10_ROOT   = r'E:\\stl10'\n",
    "INTEL_TRAIN  = r'C:\\Users\\Acer\\Downloads\\Intel Image Classification\\seg_train\\seg_train'\n",
    "INTEL_TEST   = r'C:\\Users\\Acer\\Downloads\\Intel Image Classification\\seg_test\\seg_test'\n",
    "OUTPUT_DIR   = r'E:\\decision_consistency_novelty'\n",
    "\n",
    "# Consistency summary CSVs (produced by notebooks 01–03, 11)\n",
    "CONSISTENCY_CSVS = {\n",
    "    'CIFAR-10':    r'E:\\decision_consistency_cifar_outputs\\tables\\summary_table.csv',\n",
    "    'STL-10':      r'E:\\decision_consistency_stl10_outputs\\tables\\summary_table_stl10.csv',\n",
    "    'Intel-Scene': r'E:\\decision_consistency_intel_outputs\\tables\\summary_table_intel.csv',\n",
    "    'OCTMNIST':    r'E:\\decision_consistency_octmnist_outputs\\tables\\summary_table_octmnist.csv',\n",
    "}\n",
    "\n",
    "BATCH_SIZE = 128\n",
    "EPOCHS     = 3\n",
    "LR         = 1e-3\n",
    "SEED       = 42"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import os, csv, random, gc\n",
    "import numpy as np\n",
    "import torch, torch.nn as nn, torch.nn.functional as F\n",
    "import torch.optim as optim\n",
    "from torchvision import models, transforms, datasets\n",
    "from torch.utils.data import DataLoader\n",
    "from scipy.stats import pearsonr\n",
    "import matplotlib\n",
    "matplotlib.use('Agg')\n",
    "import matplotlib.pyplot as plt\n",
    "from tqdm import tqdm\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "os.makedirs(OUTPUT_DIR, exist_ok=True)\n",
    "random.seed(SEED); np.random.seed(SEED); torch.manual_seed(SEED)\n",
    "if torch.cuda.is_available(): torch.cuda.manual_seed_all(SEED)\n",
    "device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n",
    "print('Device:', device)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Build dataloaders for all 4 datasets\n",
    "preprocess = transforms.Compose([\n",
    "    transforms.Resize((224, 224)), transforms.ToTensor(),\n",
    "    transforms.Normalize(mean=[0.485,0.456,0.406], std=[0.229,0.224,0.225]),\n",
    "])\n",
    "\n",
    "train_loaders, test_loaders, num_classes_map = {}, {}, {}\n",
    "\n",
    "# CIFAR-10\n",
    "c10_train = datasets.CIFAR10(root=CIFAR_ROOT, train=True,  transform=preprocess, download=False)\n",
    "c10_test  = datasets.CIFAR10(root=CIFAR_ROOT, train=False, transform=preprocess, download=False)\n",
    "train_loaders['CIFAR-10'] = DataLoader(c10_train, batch_size=BATCH_SIZE, shuffle=False)\n",
    "test_loaders['CIFAR-10']  = DataLoader(torch.utils.data.Subset(c10_test, range(1000)),\n",
    "                                        batch_size=BATCH_SIZE, shuffle=False)\n",
    "num_classes_map['CIFAR-10'] = 10\n",
    "\n",
    "# STL-10\n",
    "stl_train = datasets.STL10(root=STL10_ROOT, split='train', transform=preprocess, download=False)\n",
    "stl_test  = datasets.STL10(root=STL10_ROOT, split='test',  transform=preprocess, download=False)\n",
    "train_loaders['STL-10'] = DataLoader(stl_train, batch_size=BATCH_SIZE, shuffle=False)\n",
    "test_loaders['STL-10']  = DataLoader(torch.utils.data.Subset(stl_test, range(1000)),\n",
    "                                      batch_size=BATCH_SIZE, shuffle=False)\n",
    "num_classes_map['STL-10'] = 10\n",
    "\n",
    "# Intel Scene\n",
    "intel_train = datasets.ImageFolder(root=INTEL_TRAIN, transform=preprocess)\n",
    "intel_test  = datasets.ImageFolder(root=INTEL_TEST,  transform=preprocess)\n",
    "all_idx = list(range(len(intel_test)))\n",
    "random.seed(SEED); random.shuffle(all_idx)\n",
    "train_loaders['Intel-Scene'] = DataLoader(intel_train, batch_size=BATCH_SIZE, shuffle=False)\n",
    "test_loaders['Intel-Scene']  = DataLoader(torch.utils.data.Subset(intel_test, all_idx[:1000]),\n",
    "                                           batch_size=BATCH_SIZE, shuffle=False)\n",
    "num_classes_map['Intel-Scene'] = 6\n",
    "\n",
    "# OCTMNIST\n",
    "try:\n",
    "    from medmnist import OCTMNIST\n",
    "    import medmnist\n",
    "    oct_train = OCTMNIST(split='train', transform=transforms.Compose([\n",
    "        transforms.Grayscale(3), preprocess]), download=True)\n",
    "    oct_test  = OCTMNIST(split='test',  transform=transforms.Compose([\n",
    "        transforms.Grayscale(3), preprocess]), download=True)\n",
    "    train_loaders['OCTMNIST'] = DataLoader(oct_train, batch_size=BATCH_SIZE, shuffle=False)\n",
    "    test_loaders['OCTMNIST']  = DataLoader(torch.utils.data.Subset(\n",
    "        oct_test, range(min(1000, len(oct_test)))), batch_size=BATCH_SIZE, shuffle=False)\n",
    "    num_classes_map['OCTMNIST'] = 4\n",
    "    print('OCTMNIST loaded.')\n",
    "except ImportError:\n",
    "    print('medmnist not installed — skipping OCTMNIST. Run: pip install medmnist')\n",
    "\n",
    "print('Datasets ready:', list(train_loaders.keys()))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def get_feature_extractor(model, model_name):\n",
    "    if 'ResNet' in model_name:\n",
    "        return nn.Sequential(*list(model.children())[:-1])\n",
    "    elif 'VGG' in model_name:\n",
    "        class VGGF(nn.Module):\n",
    "            def __init__(self, m): super().__init__(); self.f=m.features; self.a=m.avgpool\n",
    "            def forward(self, x): return self.a(self.f(x)).view(x.size(0),-1)\n",
    "        return VGGF(model)\n",
    "    else:  # MobileNet\n",
    "        class MNF(nn.Module):\n",
    "            def __init__(self, m): super().__init__(); self.f=m.features\n",
    "            def forward(self, x): return F.adaptive_avg_pool2d(self.f(x),(1,1)).view(x.size(0),-1)\n",
    "        return MNF(model)\n",
    "\n",
    "\n",
    "def compute_ece(confs, corrects, n_bins=10):\n",
    "    bins = np.linspace(0, 1, n_bins+1); ece = 0.0\n",
    "    for i in range(n_bins):\n",
    "        mask = (confs>=bins[i]) & (confs<bins[i+1])\n",
    "        if mask.sum() == 0: continue\n",
    "        ece += np.abs(np.mean(confs[mask]) - np.mean(corrects[mask])) * (mask.sum()/len(confs))\n",
    "    return ece\n",
    "\n",
    "\n",
    "def run_linear_probe(ds_name, model_name, model_fn, n_classes, train_dl, test_dl, device):\n",
    "    backbone = model_fn(pretrained=True).eval().to(device)\n",
    "    for p in backbone.parameters(): p.requires_grad = False\n",
    "    extractor = get_feature_extractor(backbone, model_name).eval().to(device)\n",
    "\n",
    "    # Infer feature dim\n",
    "    dummy = next(iter(train_dl))[0][:1].to(device)\n",
    "    with torch.no_grad(): feat_dim = extractor(dummy).shape[1]\n",
    "    del dummy\n",
    "\n",
    "    head = nn.Linear(feat_dim, n_classes).to(device)\n",
    "    optimizer = optim.Adam(head.parameters(), lr=LR)\n",
    "    criterion = nn.CrossEntropyLoss()\n",
    "\n",
    "    head.train()\n",
    "    for epoch in range(EPOCHS):\n",
    "        for imgs, labels in tqdm(train_dl, desc=f'{ds_name}/{model_name} ep{epoch+1}', leave=False):\n",
    "            imgs = imgs.to(device)\n",
    "            # OCTMNIST labels come as (N,1) tensors\n",
    "            labels = labels.squeeze().long().to(device)\n",
    "            with torch.no_grad(): feats = extractor(imgs)\n",
    "            if feats.ndim > 2: feats = feats.view(feats.size(0),-1)\n",
    "            optimizer.zero_grad()\n",
    "            loss = criterion(head(feats), labels)\n",
    "            loss.backward(); optimizer.step()\n",
    "            del feats, loss\n",
    "\n",
    "    head.eval()\n",
    "    all_confs, all_corrects = [], []\n",
    "    with torch.no_grad():\n",
    "        for imgs, labels in test_dl:\n",
    "            imgs = imgs.to(device)\n",
    "            labels = labels.squeeze().long().to(device)\n",
    "            feats = extractor(imgs)\n",
    "            if feats.ndim > 2: feats = feats.view(feats.size(0),-1)\n",
    "            probs = F.softmax(head(feats), dim=1)\n",
    "            confs, preds = probs.max(dim=1)\n",
    "            all_confs.append(confs.cpu().numpy())\n",
    "            all_corrects.append((preds==labels).cpu().numpy())\n",
    "\n",
    "    confs_np = np.concatenate(all_confs)\n",
    "    corr_np  = np.concatenate(all_corrects)\n",
    "    acc = corr_np.mean()\n",
    "    ece = compute_ece(confs_np, corr_np)\n",
    "\n",
    "    del backbone, extractor, head, optimizer\n",
    "    gc.collect(); torch.cuda.empty_cache()\n",
    "    return round(acc,4), round(ece,4)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Run all probes\n",
    "model_fns_map = {\n",
    "    'ResNet-18':   models.resnet18,\n",
    "    'ResNet-50':   models.resnet50,\n",
    "    'VGG-16':      models.vgg16,\n",
    "    'MobileNetV2': models.mobilenet_v2,\n",
    "}\n",
    "\n",
    "probe_results = []\n",
    "for ds_name in train_loaders:\n",
    "    for mn, fn in model_fns_map.items():\n",
    "        acc, ece = run_linear_probe(\n",
    "            ds_name, mn, fn, num_classes_map[ds_name],\n",
    "            train_loaders[ds_name], test_loaders[ds_name], device\n",
    "        )\n",
    "        probe_results.append({'Dataset':ds_name,'Model':mn,'Accuracy':acc,'ECE':ece})\n",
    "        print(f'{ds_name:14} {mn:14} Acc={acc:.3f}  ECE={ece:.3f}')\n",
    "\n",
    "# Save\n",
    "csv_path = os.path.join(OUTPUT_DIR, 'accuracy_ece_linear_probe.csv')\n",
    "with open(csv_path, 'w', newline='') as f:\n",
    "    w = csv.DictWriter(f, fieldnames=['Dataset','Model','Accuracy','ECE'])\n",
    "    w.writeheader(); w.writerows(probe_results)\n",
    "print('Saved:', csv_path)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Merge with consistency scores → corrected CAG\n",
    "def load_consistency(path):\n",
    "    if not os.path.exists(path): return {}\n",
    "    with open(path) as f:\n",
    "        return {(r['Dataset'],r['Model']): float(r['Avg_Consistency_Score'])\n",
    "                for r in csv.DictReader(f)}\n",
    "\n",
    "cs_map = {}\n",
    "for ds, path in CONSISTENCY_CSVS.items():\n",
    "    cs_map.update(load_consistency(path))\n",
    "\n",
    "final_rows = []\n",
    "for row in probe_results:\n",
    "    key = (row['Dataset'], row['Model'])\n",
    "    cs  = cs_map.get(key)\n",
    "    if cs is None: continue\n",
    "    final_rows.append({**row, 'Avg_CS':round(cs,4), 'CAG':round(row['Accuracy']-cs,4)})\n",
    "\n",
    "print(f'{\"Dataset\":<14} {\"Model\":<14} {\"Acc\":>7} {\"ECE\":>7} {\"CS\":>7} {\"CAG\":>8}')\n",
    "print('-' * 65)\n",
    "for r in sorted(final_rows, key=lambda x: x['Dataset']):\n",
    "    print(f\"{r['Dataset']:<14} {r['Model']:<14} {r['Accuracy']:7.3f} \"\n",
    "          f\"{r['ECE']:7.3f} {r['Avg_CS']:7.3f} {r['CAG']:8.4f}\")\n",
    "\n",
    "final_csv = os.path.join(OUTPUT_DIR, 'final_accuracy_ece_cag_4datasets.csv')\n",
    "with open(final_csv, 'w', newline='') as f:\n",
    "    w = csv.DictWriter(f, fieldnames=['Dataset','Model','Accuracy','ECE','Avg_CS','CAG'])\n",
    "    w.writeheader(); w.writerows(final_rows)\n",
    "print('Saved:', final_csv)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ECE vs CS scatter (all 16 points)\n",
    "if final_rows:\n",
    "    ece_v = [r['ECE']    for r in final_rows]\n",
    "    cs_v  = [r['Avg_CS'] for r in final_rows]\n",
    "    r_val, p_val = pearsonr(ece_v, cs_v)\n",
    "\n",
    "    fig, axes = plt.subplots(1, 2, figsize=(12, 5))\n",
    "\n",
    "    ax = axes[0]\n",
    "    ax.scatter(ece_v, cs_v, color='steelblue', s=70)\n",
    "    for row in final_rows:\n",
    "        ax.annotate(f\"{row['Dataset'][:4]} {row['Model'][:4]}\",\n",
    "                    (row['ECE'], row['Avg_CS']), fontsize=7)\n",
    "    ax.set_xlabel('ECE', fontsize=11); ax.set_ylabel('Consistency Score', fontsize=11)\n",
    "    ax.set_title(f'ECE vs CS (Pearson r={r_val:.2f}, p={p_val:.3f})', fontsize=11)\n",
    "    ax.grid(alpha=0.3)\n",
    "\n",
    "    ax = axes[1]\n",
    "    sorted_r = sorted(final_rows, key=lambda x: x['CAG'])\n",
    "    labels   = [f\"{r['Dataset'][:4]} {r['Model'][:6]}\" for r in sorted_r]\n",
    "    cag_v    = [r['CAG'] for r in sorted_r]\n",
    "    ax.bar(labels, cag_v, color=['tomato' if v>0 else 'steelblue' for v in cag_v])\n",
    "    ax.axhline(0, color='black', lw=1.5)\n",
    "    ax.set_ylabel('CAG'); ax.tick_params(axis='x', rotation=45)\n",
    "    ax.set_title('CAG Dichotomy — All Configurations', fontsize=11)\n",
    "    ax.grid(axis='y', alpha=0.3)\n",
    "\n",
    "    plt.tight_layout()\n",
    "    path = os.path.join(OUTPUT_DIR, 'ece_cag_final_16configs.png')\n",
    "    plt.savefig(path, dpi=300, bbox_inches='tight'); plt.close()\n",
    "    print('Saved:', path)"
   ]
  }
