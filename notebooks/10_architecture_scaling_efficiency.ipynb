{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Architecture Scaling and Efficiency Study\n",
    "\n",
    "Analyses DCF metrics across the full model spectrum:\n",
    "- Consistency Score vs model depth (layers)\n",
    "- Consistency Score vs parameter count (efficiency frontier)\n",
    "- Per-perturbation impact heatmap across all 4 models × 4 datasets\n",
    "- Composite efficiency score: CS / √Params and CS / inference_ms\n",
    "\n",
    "All results are drawn from the empirical data collected in notebooks 01–03.\n",
    "No additional model runs required."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "OUTPUT_DIR = r'E:\\decision_consistency_scaling'"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import os, csv\n",
    "import numpy as np\n",
    "import matplotlib\n",
    "matplotlib.use('Agg')\n",
    "import matplotlib.pyplot as plt\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "os.makedirs(OUTPUT_DIR, exist_ok=True)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Full empirical results (16 configurations)\n",
    "data = [\n",
    "    # (dataset, model, acc, LS, CD, CS, depth, params_M, inference_ms)\n",
    "    ('CIFAR-10',    'ResNet-18',   0.876, 0.6935, 0.1291, 0.7822, 18,  11.7, 1.2),\n",
    "    ('CIFAR-10',    'ResNet-50',   0.865, 0.7193, 0.1415, 0.7889, 50,  25.6, 2.1),\n",
    "    ('CIFAR-10',    'VGG-16',      0.856, 0.6668, 0.1134, 0.7767, 16, 138.4, 5.3),\n",
    "    ('CIFAR-10',    'MobileNetV2', 0.874, 0.6848, 0.1335, 0.7757, 53,   3.5, 0.8),\n",
    "    ('STL-10',      'ResNet-18',   0.939, 0.8210, 0.1067, 0.8571, 18,  11.7, 1.2),\n",
    "    ('STL-10',      'ResNet-50',   0.969, 0.8512, 0.1051, 0.8730, 50,  25.6, 2.1),\n",
    "    ('STL-10',      'VGG-16',      0.936, 0.8000, 0.0844, 0.8383, 16, 138.4, 5.3),\n",
    "    ('STL-10',      'MobileNetV2', 0.935, 0.8227, 0.1171, 0.8538, 53,   3.5, 0.8),\n",
    "    ('Intel-Scene', 'ResNet-18',   0.574, 0.8127, 0.0809, 0.8659, 18,  11.7, 1.2),\n",
    "    ('Intel-Scene', 'ResNet-50',   0.526, 0.7993, 0.0955, 0.8478, 50,  25.6, 2.1),\n",
    "    ('Intel-Scene', 'VGG-16',      0.742, 0.7880, 0.0916, 0.8484, 16, 138.4, 5.3),\n",
    "    ('Intel-Scene', 'MobileNetV2', 0.599, 0.7725, 0.0949, 0.8388, 53,   3.5, 0.8),\n",
    "    ('OCTMNIST',    'ResNet-18',   0.470, 0.7683, 0.0460, 0.8612, 18,  11.7, 1.2),\n",
    "    ('OCTMNIST',    'ResNet-50',   0.526, 0.7455, 0.0576, 0.8466, 50,  25.6, 2.1),\n",
    "    ('OCTMNIST',    'VGG-16',      0.628, 0.7097, 0.0219, 0.8303, 16, 138.4, 5.3),\n",
    "    ('OCTMNIST',    'MobileNetV2', 0.513, 0.7167, 0.0799, 0.8146, 53,   3.5, 0.8),\n",
    "]\n",
    "\n",
    "models_unique  = ['ResNet-18', 'ResNet-50', 'VGG-16', 'MobileNetV2']\n",
    "datasets_unique = ['CIFAR-10', 'STL-10', 'Intel-Scene', 'OCTMNIST']\n",
    "\n",
    "# Average CS per model across all datasets\n",
    "avg_cs = {m: np.mean([cs for ds,model,acc,ls,cd,cs,*_ in data if model == m])\n",
    "          for m in models_unique}\n",
    "print('Average CS per model:')\n",
    "for m, v in avg_cs.items(): print(f'  {m:<14}: {v:.4f}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# CS vs depth scatter\n",
    "depths = [18, 50, 16, 53]\n",
    "params = [11.7, 25.6, 138.4, 3.5]\n",
    "cs_cifar = [next(cs for ds,m,_,__,___,cs,*_ in data if ds=='CIFAR-10' and m==mn)\n",
    "            for mn in models_unique]\n",
    "cs_stl   = [next(cs for ds,m,_,__,___,cs,*_ in data if ds=='STL-10' and m==mn)\n",
    "            for mn in models_unique]\n",
    "\n",
    "fig, axes = plt.subplots(1, 2, figsize=(12, 5))\n",
    "\n",
    "ax = axes[0]\n",
    "for cs_list, label, color in [(cs_cifar,'CIFAR-10','steelblue'), (cs_stl,'STL-10','darkorange')]:\n",
    "    ax.scatter(depths, cs_list, s=120, label=label, color=color)\n",
    "    for d, v, mn in zip(depths, cs_list, models_unique):\n",
    "        ax.annotate(mn[:6], (d, v), fontsize=8, ha='center', va='bottom')\n",
    "ax.set_xlabel('Model Depth (layers)', fontsize=11)\n",
    "ax.set_ylabel('Consistency Score', fontsize=11)\n",
    "ax.set_title('CS vs Architecture Depth', fontsize=11)\n",
    "ax.legend(); ax.grid(alpha=0.3)\n",
    "\n",
    "ax = axes[1]\n",
    "for cs_list, label, color in [(cs_cifar,'CIFAR-10','steelblue'), (cs_stl,'STL-10','darkorange')]:\n",
    "    ax.scatter(params, cs_list, s=120, label=label, color=color)\n",
    "    for p, v, mn in zip(params, cs_list, models_unique):\n",
    "        ax.annotate(mn[:6], (p, v), fontsize=8, ha='center', va='bottom')\n",
    "ax.set_xlabel('Parameters (millions)', fontsize=11)\n",
    "ax.set_xscale('log')\n",
    "ax.set_title('Efficiency Frontier: CS vs Model Size', fontsize=11)\n",
    "ax.legend(); ax.grid(alpha=0.3)\n",
    "\n",
    "fig.suptitle('Architecture Scaling Analysis — DCF', fontsize=12)\n",
    "plt.tight_layout()\n",
    "path = os.path.join(OUTPUT_DIR, 'architecture_scaling.png')\n",
    "plt.savefig(path, dpi=300, bbox_inches='tight'); plt.close()\n",
    "print('Saved:', path)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Heatmap: CS per model × dataset\n",
    "cs_matrix = np.array([[next(cs for ds,m,_,__,___,cs,*_ in data\n",
    "                            if ds==dataset and m==model)\n",
    "                       for dataset in datasets_unique]\n",
    "                      for model in models_unique])\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(8, 5))\n",
    "im = ax.imshow(cs_matrix, cmap='RdYlGn', vmin=0.75, vmax=0.90)\n",
    "ax.set_xticks(range(len(datasets_unique)))\n",
    "ax.set_yticks(range(len(models_unique)))\n",
    "ax.set_xticklabels(datasets_unique, fontsize=10)\n",
    "ax.set_yticklabels(models_unique, fontsize=10)\n",
    "for i in range(len(models_unique)):\n",
    "    for j in range(len(datasets_unique)):\n",
    "        ax.text(j, i, f'{cs_matrix[i,j]:.3f}', ha='center', va='center', fontsize=11)\n",
    "plt.colorbar(im, ax=ax, label='Consistency Score')\n",
    "ax.set_title('Consistency Score Heatmap — Models × Datasets', fontsize=12)\n",
    "plt.tight_layout()\n",
    "path = os.path.join(OUTPUT_DIR, 'cs_heatmap.png')\n",
    "plt.savefig(path, dpi=300, bbox_inches='tight'); plt.close()\n",
    "print('Saved:', path)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Efficiency scores\n",
    "print(f'{\"Model\":<14} {\"CS_avg\":>8} {\"Params\":>8} {\"CS/√P\":>10} {\"CS/ms\":>10}')\n",
    "print('-' * 55)\n",
    "rows = []\n",
    "for i, mn in enumerate(models_unique):\n",
    "    cs_avg  = avg_cs[mn]\n",
    "    p       = params[i]\n",
    "    ms      = [1.2, 2.1, 5.3, 0.8][i]\n",
    "    eff_p   = cs_avg / (p ** 0.5)\n",
    "    eff_ms  = cs_avg / ms\n",
    "    print(f'{mn:<14} {cs_avg:>8.4f} {p:>8.1f} {eff_p:>10.4f} {eff_ms:>10.4f}')\n",
    "    rows.append({'Model':mn,'CS_avg':round(cs_avg,4),'Params_M':p,\n",
    "                 'Efficiency_CS_per_sqrtP':round(eff_p,4),\n",
    "                 'Efficiency_CS_per_ms':round(eff_ms,4)})\n",
    "\n",
    "csv_path = os.path.join(OUTPUT_DIR, 'efficiency_scores.csv')\n",
    "with open(csv_path, 'w', newline='') as f:\n",
    "    w = csv.DictWriter(f, fieldnames=list(rows[0].keys()))\n",
    "    w.writeheader(); w.writerows(rows)\n",
    "print('Saved:', csv_path)"
   ]
  }
 ],
 "metadata": {\n  \"kernelspec\": {\"display_name\": \"Python 3\", \"language\": \"python\", \"name\": \"python3\"},\n  \"language_info\": {\"name\": \"python\", \"version\": \"3.9.0\"}\n },
 "nbformat": 4,
