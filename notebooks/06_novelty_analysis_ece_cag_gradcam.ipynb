 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Novelty Analysis — ECE, CAG, and Grad-CAM Shift\n",
    "\n",
    "Reads the raw JSON outputs produced by notebooks 01–03 and computes additional novelty metrics:\n",
    "- **ECE (Expected Calibration Error):** per model per dataset\n",
    "- **CAG (Consistency–Accuracy Gap):** identifies Overconfident vs Consistently Wrong failure modes\n",
    "- **Grad-CAM Cosine Shift:** bar chart showing attention map drift for stable vs flipped predictions\n",
    "\n",
    "These analyses are designed to strengthen the paper's novelty argument beyond accuracy-only evaluation.\n",
    "\n",
    "**Prereq:** run notebooks 01–03 first so the raw JSON outputs exist in their output directories."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Configuration ────────────────────────────────────────────────────────────\n",
    "BASE_CIFAR  = r'E:\\decision_consistency_cifar_outputs\\tables'\n",
    "BASE_STL10  = r'E:\\decision_consistency_stl10_outputs\\tables'\n",
    "BASE_INTEL  = r'E:\\decision_consistency_intel_outputs\\tables'\n",
    "OUTPUT_DIR  = r'E:\\decision_consistency_novelty'"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import os, json, csv\n",
    "import numpy as np\n",
    "from scipy.stats import pearsonr\n",
    "from collections import defaultdict\n",
    "import matplotlib\n",
    "matplotlib.use('Agg')\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "os.makedirs(OUTPUT_DIR, exist_ok=True)\n",
    "\n",
    "datasets_info = {\n",
    "    'CIFAR-10': BASE_CIFAR,\n",
    "    'STL-10':   BASE_STL10,\n",
    "    'Intel':    BASE_INTEL,\n",
    "}"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Load all raw JSON files\n",
    "all_data = {}\n",
    "\n",
    "for ds_name, base in datasets_info.items():\n",
    "    all_data[ds_name] = {}\n",
    "    if not os.path.isdir(base):\n",
    "        print(f'WARNING: {base} not found — skipping {ds_name}')\n",
    "        continue\n",
    "    for fname in os.listdir(base):\n",
    "        if not (fname.startswith('raw_') and fname.endswith('.json')):\n",
    "            continue\n",
    "        with open(os.path.join(base, fname)) as f:\n",
    "            samples = json.load(f)\n",
    "        parts = fname.replace('raw_','').replace('.json','').split('_')\n",
    "        # Reconstruct model name from filename tokens\n",
    "        model_raw = '_'.join(parts[2:])\n",
    "        model_name = (model_raw\n",
    "                      .replace('ResNet_18','ResNet-18')\n",
    "                      .replace('ResNet_50','ResNet-50')\n",
    "                      .replace('VGG_16','VGG-16'))\n",
    "        all_data[ds_name][model_name] = samples\n",
    "\n",
    "print('Datasets loaded:')\n",
    "for ds, models in all_data.items():\n",
    "    print(f'  {ds}: {list(models.keys())}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def compute_ece(confs, corrects, n_bins=10):\n",
    "    \"\"\"Expected Calibration Error.\"\"\"\n",
    "    bins = np.linspace(0, 1, n_bins + 1)\n",
    "    ece  = 0.0\n",
    "    for i in range(n_bins):\n",
    "        mask = (confs >= bins[i]) & (confs < bins[i+1])\n",
    "        if mask.sum() == 0:\n",
    "            continue\n",
    "        avg_conf = np.mean(confs[mask])\n",
    "        avg_acc  = np.mean(corrects[mask])\n",
    "        ece += np.abs(avg_conf - avg_acc) * (mask.sum() / len(confs))\n",
    "    return ece\n",
    "\n",
    "\n",
    "results_table = []\n",
    "\n",
    "for ds_name in all_data:\n",
    "    for model_name, samples in all_data[ds_name].items():\n",
    "        true_labels = np.array([s['true_label'] for s in samples])\n",
    "        preds       = np.array([s['orig_pred']  for s in samples])\n",
    "        confs       = np.array([s['orig_conf']  for s in samples])\n",
    "        cs_arr      = np.array([s.get('Consistency_Score', 0) for s in samples])\n",
    "\n",
    "        accuracy = np.mean(preds == true_labels)\n",
    "        ece      = compute_ece(confs, preds == true_labels)\n",
    "        avg_cs   = np.mean(cs_arr)\n",
    "        cag      = accuracy - avg_cs\n",
    "\n",
    "        results_table.append({\n",
    "            'Dataset':  ds_name,\n",
    "            'Model':    model_name,\n",
    "            'Accuracy': round(accuracy, 4),\n",
    "            'ECE':      round(ece,      4),\n",
    "            'Avg_CS':   round(avg_cs,   4),\n",
    "            'CAG':      round(cag,      4),\n",
    "        })\n",
    "\n",
    "csv_path = os.path.join(OUTPUT_DIR, 'accuracy_ece_cag.csv')\n",
    "with open(csv_path, 'w', newline='') as f:\n",
    "    w = csv.DictWriter(f, fieldnames=['Dataset','Model','Accuracy','ECE','Avg_CS','CAG'])\n",
    "    w.writeheader(); w.writerows(results_table)\n",
    "print('Saved:', csv_path)\n",
    "\n",
    "print(f'\\n{\"Dataset\":<12} {\"Model\":<14} {\"Acc\":>6} {\"ECE\":>6} {\"CS\":>6} {\"CAG\":>7}')\n",
    "print('-' * 55)\n",
    "for r in sorted(results_table, key=lambda x: x['Dataset']):\n",
    "    print(f\"{r['Dataset']:<12} {r['Model']:<14} {r['Accuracy']:6.3f} \"\n",
    "          f\"{r['ECE']:6.3f} {r['Avg_CS']:6.3f} {r['CAG']:7.4f}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ECE vs CS scatter\n",
    "if results_table:\n",
    "    ece_vals = [r['ECE']    for r in results_table]\n",
    "    cs_vals  = [r['Avg_CS'] for r in results_table]\n",
    "    r_val, p_val = pearsonr(ece_vals, cs_vals)\n",
    "\n",
    "    fig, ax = plt.subplots(figsize=(7, 5))\n",
    "    ax.scatter(ece_vals, cs_vals, color='steelblue', s=70)\n",
    "    for row in results_table:\n",
    "        ax.annotate(row['Model'][:6], (row['ECE'], row['Avg_CS']), fontsize=8, alpha=0.7)\n",
    "    ax.set_xlabel('ECE', fontsize=12)\n",
    "    ax.set_ylabel('Average Consistency Score', fontsize=12)\n",
    "    ax.set_title(f'ECE vs Consistency Score\\nPearson r={r_val:.2f} (p={p_val:.3f})', fontsize=12)\n",
    "    ax.grid(alpha=0.3)\n",
    "    plt.tight_layout()\n",
    "    path = os.path.join(OUTPUT_DIR, 'ece_vs_cs.png')\n",
    "    plt.savefig(path, dpi=300, bbox_inches='tight'); plt.close()\n",
    "    print('Saved:', path)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# CAG bar chart — lower (more negative) = more 'consistently wrong'\n",
    "if results_table:\n",
    "    sorted_r = sorted(results_table, key=lambda x: x['CAG'])\n",
    "    labels   = [f\"{r['Dataset'][:4]} {r['Model'][:8]}\" for r in sorted_r]\n",
    "    cag_vals = [r['CAG'] for r in sorted_r]\n",
    "    colors   = ['tomato' if v > 0 else 'steelblue' for v in cag_vals]\n",
    "\n",
    "    fig, ax = plt.subplots(figsize=(13, 5))\n",
    "    ax.bar(labels, cag_vals, color=colors)\n",
    "    ax.axhline(0, color='black', linewidth=1.5)\n",
    "    ax.set_ylabel('CAG  (Accuracy − Consistency Score)', fontsize=11)\n",
    "    ax.set_title('Consistency–Accuracy Gap\\n'\n",
    "                 'Red = Overconfident (CAG > 0)   Blue = Consistently Wrong (CAG < 0)', fontsize=11)\n",
    "    ax.tick_params(axis='x', rotation=45)\n",
    "    ax.grid(axis='y', alpha=0.3)\n",
    "    plt.tight_layout()\n",
    "    path = os.path.join(OUTPUT_DIR, 'cag_bar.png')\n",
    "    plt.savefig(path, dpi=300, bbox_inches='tight'); plt.close()\n",
    "    print('Saved:', path)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Grad-CAM cosine similarity — stable vs flipped predictions (STL-10, from notebook 02 results)\n",
    "# Values sourced from quantitative GradCAM analysis\n",
    "cam_data = {\n",
    "    'ResNet-18':   (0.991, 0.922),\n",
    "    'ResNet-50':   (0.986, 0.883),\n",
    "    'VGG-16':      (0.953, 0.832),\n",
    "    'MobileNetV2': (0.991, 0.954),\n",
    "}\n",
    "\n",
    "model_names  = list(cam_data.keys())\n",
    "stable_vals  = [cam_data[m][0] for m in model_names]\n",
    "flipped_vals = [cam_data[m][1] for m in model_names]\n",
    "x, w = np.arange(len(model_names)), 0.35\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(8, 5))\n",
    "ax.bar(x - w/2, stable_vals,  w, label='Label Stable',  color='steelblue')\n",
    "ax.bar(x + w/2, flipped_vals, w, label='Label Flipped', color='tomato')\n",
    "ax.set_xticks(x); ax.set_xticklabels(model_names)\n",
    "ax.set_ylim(0.80, 1.0)\n",
    "ax.set_ylabel('Mean CAM Cosine Similarity', fontsize=11)\n",
    "ax.set_title('Grad-CAM Shift: Stable vs Flipped Predictions\\nSTL-10 (rotation +2°)', fontsize=11)\n",
    "ax.legend(); ax.grid(axis='y', alpha=0.3)\n",
    "plt.tight_layout()\n",
    "path = os.path.join(OUTPUT_DIR, 'gradcam_shift.png')\n",
    "plt.savefig(path, dpi=300, bbox_inches='tight'); plt.close()\n",
    "print('Saved:', path)"
   ]
  }
 ],
